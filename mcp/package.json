{
  "name": "@yama662607/obsidian-companion-mcp",
  "version": "0.1.2",
  "description": "MCP server for Obsidian Companion Plugin",
  "author": "yama662607",
  "license": "MIT",
  "keywords": [
    "mcp",
    "obsidian",
    "mcp-server",
    "ai-agent"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yama662607/obsidian-companion-mcp.git",
    "directory": "mcp"
  },
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "obsidian-companion": "dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean --dts",
    "dev": "tsup src/index.ts --format esm --watch --sourcemap",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3"
  }
}
